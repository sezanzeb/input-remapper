# dockerfile that runs unit-tests
FROM python:3.14-slim
WORKDIR /app

RUN apt update
RUN apt install \
    libgirepository-2.0-dev gcc libcairo2-dev pkg-config python3-dev \
    libgtk-3-dev gir1.2-gtk-3.0 gir1.2-gtksource-4 gobject-introspection -y

# Or mount the project directory as a volume to test local changes more easily
COPY ./inputremapper ./inputremapper
COPY ./tests ./tests
COPY ./pyproject.toml ./

RUN pip install -e .

RUN useradd -m test
USER test

ENV DOCKER=1

CMD ["python3", "-m", "unittest", "discover", "-s", "./tests/unit"]
